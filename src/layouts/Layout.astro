---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'HoursServed',
  description = 'Attendance and volunteer hour tracking for service-led organizations.',
  canonical
} = Astro.props;

// Auto-generate canonical from current URL if not provided
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
