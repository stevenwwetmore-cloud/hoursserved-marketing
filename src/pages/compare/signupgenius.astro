---
import Layout from '../../layouts/Layout.astro';
import MarketingNav from '../../components/MarketingNav';
import MarketingFooter from '../../components/MarketingFooter';
import { CheckCircle, X } from 'lucide-react';

const ROWS = [
  { feature: 'Automatic service-hour logging on confirmation', hs: true, them: false },
  { feature: 'Email YES/NO confirmation (no member login)', hs: true, them: false },
  { feature: 'Frozen hours at event creation', hs: true, them: false },
  { feature: 'Monthly PDF/CSV reports', hs: true, them: false },
  { feature: 'Month locking and timestamped audit trail', hs: true, them: false },
  { feature: 'Automatic nudge reminders (14d, 7d, 48h, 4h)', hs: true, them: true },
  { feature: 'Multi-day events with shift management & role-based signups', hs: true, them: false },
  { feature: 'Manual member adjustment (add/remove from any event)', hs: true, them: false },
  { feature: 'Dues & payment tracking', hs: true, them: false },
  { feature: 'District leaderboard & interclub reporting', hs: true, them: false },
  { feature: 'Volunteer sign-up sheets', hs: false, them: true },
  { feature: 'No setup fee on paid plans', hs: true, them: true },
  { feature: 'Free plan available', hs: true, them: true },
];

const FAQ = [
  { q: 'Does SignUpGenius log service hours?', a: 'SignUpGenius is a sign-up sheet tool. It confirms who signed up — it doesn\'t log service hours automatically. With HoursServed, hours are captured the moment a member confirms attendance.' },
  { q: 'Can I use HoursServed for shift sign-ups?', a: 'Yes — HoursServed supports multi-day events with shift management, role-based signups, and per-day scheduling. Members receive an email, confirm YES or NO, and hours are logged automatically.' },
  { q: 'Do my members need to create accounts?', a: 'No. HoursServed is email-only for members. No account, no app, no password. That\'s core to how the system works.' },
  { q: 'Does HoursServed handle dues and payments?', a: 'Yes. HoursServed includes dues requests, payment tracking per member, and Interac e-Transfer support for Canadian organizations — something SignUpGenius doesn\'t offer.' },
  { q: 'Which is better for parent councils or booster groups?', a: 'If you primarily need people to sign up for slots on a public sheet, SignUpGenius may fit better. If you need attendance tracked, hours logged automatically, and payments or reporting managed in one place, HoursServed covers significantly more ground.' },
];
---

<Layout title="HoursServed vs. SignUpGenius | Which Is Better for Service Clubs?" description="Compare HoursServed.com and SignUpGenius for managing volunteers and tracking service hours. See which platform works best for your service club.">
  <div class="min-h-screen" style="background-color: #F1EFE8;">
    <MarketingNav client:load />

    <main id="main-content" tabindex="-1">

      <section class="pt-20 pb-16 px-4 text-center">
        <p class="text-sm text-gray-600 mb-3"><a href="/compare" class="font-semibold hover:underline" style={{color: '#0F6E56'}}>← Compare Overview</a></p>
        <h1 class="text-4xl font-bold text-gray-900 mb-4">HoursServed vs. SignUpGenius</h1>
        <p class="text-base text-gray-900 max-w-xl mx-auto">SignUpGenius handles sign-up sheets. HoursServed handles attendance <em>and</em> automatically logs service hours — no manual step required after confirmation.</p>
      </section>

      <!-- Best for -->
      <section class="py-12 px-4">
        <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-4">
          <div class="bg-white rounded-2xl p-5" style="border: 2px solid #0F6E56;">
            <p class="text-xs font-bold uppercase tracking-widest mb-2" style={{color: '#1E3A5F'}}>HoursServed is best for</p>
            <p class="text-base text-gray-900">Organizations that need attendance confirmed, service hours logged automatically, and payment or district reporting built in — without members ever creating an account.</p>
          </div>
          <div class="bg-white rounded-2xl p-5" style="border: 2px solid #1E3A5F;">
            <p class="text-xs font-bold uppercase tracking-widest mb-2" style={{color: '#1E3A5F'}}>SignUpGenius is best for</p>
            <p class="text-base text-gray-900">Organizations that primarily need a public sign-up grid where people claim open slots — without the service-hour tracking component.</p>
          </div>
        </div>
      </section>

      <!-- Feature table -->
      <section class="py-8 px-4">
        <div class="max-w-3xl mx-auto">
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm" style="border: 2px solid #E5E1D8;">
            <div class="grid grid-cols-3 px-6 py-3 text-white" style="background-color: #1E3A5F;">
              <div class="text-sm font-semibold">Feature</div>
              <div class="text-sm font-bold text-center">HoursServed</div>
              <div class="text-sm font-semibold text-center">SignUpGenius</div>
            </div>
            {ROWS.map(({ feature, hs, them }) => (
              <div key={feature} class="grid grid-cols-3 px-6 py-4 border-b border-gray-100 last:border-0">
                <div class="text-base text-gray-900">{feature}</div>
                <div class="flex justify-center">{hs ? <CheckCircle className="w-5 h-5 text-green-700" aria-hidden="true" /> : <X className="w-5 h-5 text-gray-600" aria-hidden="true" />}</div>
                <div class="flex justify-center">{them ? <CheckCircle className="w-5 h-5 text-green-700" aria-hidden="true" /> : <X className="w-5 h-5 text-gray-600" aria-hidden="true" />}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Choose sections -->
      <section class="py-16 px-4">
        <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl p-6" style="border: 2px solid #0F6E56;">
            <h3 class="font-bold mb-4 flex items-center gap-2" style={{color: '#1E3A5F'}}><CheckCircle className="w-5 h-5" style={{color: '#0F6E56'}} aria-hidden="true" /> Choose HoursServed if…</h3>
            <ul class="space-y-2">
              {[
                'You need service hours logged automatically — not just who signed up',
                'You run recurring events and need a clean monthly report',
                'Your members should not need to create accounts or remember passwords',
                'You need a timestamped audit trail for reporting purposes',
                'You run multi-day events, fundraisers, or service projects with shifts and roles',
                'You need dues and payment tracking alongside attendance',
                'You want to manually adjust who attended any event without workarounds',
              ].map(item => (
                <li key={item} class="text-base text-gray-900 flex items-start gap-2">
                  <CheckCircle className="w-4 h-4 flex-shrink-0 mt-0.5" style={{color: '#0F6E56'}} aria-hidden="true" />{item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-2xl p-6" style="border: 2px solid #1E3A5F;">
            <h3 class="font-bold mb-4" style={{color: '#1E3A5F'}}>Choose SignUpGenius if…</h3>
            <ul class="space-y-2">
              {[
                'You primarily need a public sign-up grid for open slots',
                'You don\'t need hours tracked or reported automatically',
                'Your use case is one-off events, not recurring service hours',
              ].map(item => (
                <li key={item} class="text-base text-gray-900 flex items-start gap-2">
                  <span class="text-gray-600 flex-shrink-0 mt-0.5">→</span>{item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Proof -->
      <section class="py-12 px-4">
        <div class="max-w-4xl mx-auto">
          <p class="text-xs font-bold text-gray-600 uppercase tracking-widest mb-6 text-center">How HoursServed works in practice</p>
          <div class="grid md:grid-cols-2 gap-6 items-start">
            <div>
              <p class="text-xs font-semibold text-gray-600 mb-2 text-center">HS-01 · Attendance Requested</p>
              <img src="https://media.base44.com/images/public/69ac4eaa5a3031dffe252cf9/901bba013_AttendanceRequestedScreenshot.png" alt="Attendance Requested" class="w-full rounded-xl shadow-md border border-gray-100" />
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-600 mb-2 text-center">HS-02 · Attendance Confirmed</p>
              <img src="https://media.base44.com/images/public/69ac4eaa5a3031dffe252cf9/9c18c9565_AttendanceConfirmedScreenshot.png" alt="Attendance Confirmed" class="w-full rounded-xl shadow-md border border-gray-100" />
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="py-16 px-4">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Frequently asked questions</h2>
          <div class="space-y-5">
            {FAQ.map(({ q, a }) => (
              <div key={q} class="border-b border-gray-100 pb-5">
                <h3 class="font-semibold text-gray-900 mb-2 text-base">{q}</h3>
                <p class="text-base text-gray-900 leading-relaxed">{a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-10 px-4">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-base text-gray-900 mb-4">Most relevant for: <a href="/solutions/parent-councils-booster-groups-youth-sports" class="font-semibold hover:underline" style={{color: '#0F6E56'}}>Parent Councils & Booster Groups</a></p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a href="/compare" class="text-base text-gray-900 border px-4 py-2 rounded-lg hover:bg-white transition-colors" style="border-color: #E5E1D8;">← All Comparisons</a>
            <a href="/pricing" class="text-base text-gray-900 border px-4 py-2 rounded-lg hover:bg-white transition-colors" style="border-color: #E5E1D8;">View Pricing</a>
            <a href="/demo" class="text-white font-bold px-4 py-2 rounded-lg transition-colors hover:bg-gray-50" style="background-color: #0F6E56;">Book a Demo</a>
          </div>
        </div>
      </section>

      <section class="py-16 px-4">
        <div class="max-w-3xl mx-auto">
          <div class="bg-white rounded-2xl p-8" style="background-color: #1E3A5F;">
            <div class="text-center">
              <h2 class="text-3xl font-bold text-white mb-4">See HoursServed in action</h2>
              <p class="text-base text-white mb-8">20 minutes. We'll show you exactly how it works for your organization.</p>
              <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="https://calendly.com/hello-klbv/hoursserved-com-demo" target="_blank" rel="noopener noreferrer" class="inline-block bg-white font-bold px-8 py-4 rounded-xl hover:bg-gray-50 transition-colors" style={{color: '#1E3A5F'}}>Book a Demo</a>
                <a href="/app/dashboard" class="inline-block bg-white font-bold px-8 py-4 rounded-xl hover:bg-gray-50 transition-colors" style={{color: '#1E3A5F'}}>Start Free</a>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>

    <MarketingFooter />
  </div>
</Layout>
